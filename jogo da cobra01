import javax.swing.*;
import java.awt.*;
import java.awt.event.*;
import java.io.*;
import java.util.ArrayList;
import java.util.Random;

public class AdvancedSnakeGame extends JPanel implements ActionListener, KeyListener {

    int tile = 25;
    int largura = 20;
    int altura = 20;

    Timer timer;
    ArrayList<Point> snake = new ArrayList<>();
    Point food;
    Point powerUp;

    int dx = 1, dy = 0;
    Random rand = new Random();

    int score = 0;
    int velocidade = 150;
    int recorde = 0;

    boolean powerUpAtivo = false;
    int powerUpTempo = 0;

    File arquivoRecorde = new File("recorde.txt");

    public AdvancedSnakeGame(){
        setPreferredSize(new Dimension(largura*tile, altura*tile));
        setBackground(Color.BLACK);
        addKeyListener(this);
        setFocusable(true);
        carregarRecorde();
        iniciarJogo();
    }

    void iniciarJogo(){
        snake.clear();
        snake.add(new Point(5,5));
        snake.add(new Point(4,5));
        snake.add(new Point(3,5));
        gerarComida();
        powerUpAtivo = false;
        score = 0;
        dx = 1; dy = 0;
        velocidade = 150;
        if(timer != null) timer.stop();
        timer = new Timer(velocidade,this);
        timer.start();
    }

    void gerarComida(){
        int x, y;
        do {
            x = rand.nextInt(largura);
            y = rand.nextInt(altura);
        } while(snake.contains(new Point(x,y)));
        food = new Point(x,y);
    }

    void gerarPowerUp(){
        int x, y;
        do{
            x = rand.nextInt(largura);
            y = rand.nextInt(altura);
        }while(snake.contains(new Point(x,y)) || food.equals(new Point(x,y)));
        powerUp = new Point(x,y);
        powerUpAtivo = true;
        powerUpTempo = 100; // dura 100 ticks
    }

    public void actionPerformed(ActionEvent e){
        moverCobra();
        if(powerUpAtivo) powerUpTempo--;
        if(powerUpAtivo && powerUpTempo<=0) powerUpAtivo=false;
        repaint();
    }

    void moverCobra(){
        Point head = snake.get(0);
        Point newHead = new Point(head.x+dx, head.y+dy);

        // Colisão
        if(newHead.x<0||newHead.x>=largura||newHead.y<0||newHead.y>=altura||snake.contains(newHead)){
            gameOver();
            return;
        }

        snake.add(0,newHead);

        // Comeu comida
        if(newHead.equals(food)){
            score++;
            gerarComida();
            acelerar();
            if(score%5==0) gerarPowerUp(); // power-up a cada 5 pontos
        } else {
            snake.remove(snake.size()-1);
        }

        // Pegou power-up
        if(powerUpAtivo && newHead.equals(powerUp)){
            velocidade = Math.max(50, velocidade-30); // aumento temporário de velocidade
            timer.setDelay(velocidade);
            powerUpAtivo=false;
        }
    }

    void acelerar(){
        if(velocidade>50){
            velocidade-=5;
            timer.setDelay(velocidade);
        }
    }

    void gameOver(){
        timer.stop();
        if(score>recorde) salvarRecorde(score);
        int opcao = JOptionPane.showOptionDialog(this,
                "Game Over! Pontuação: " + score + "\nRecorde: " + recorde + "\nJogar novamente?",
                "Fim de jogo",
                JOptionPane.YES_NO_OPTION,
                JOptionPane.INFORMATION_MESSAGE,
                null,null,null);
        if(opcao==JOptionPane.YES_OPTION) iniciarJogo();
        else System.exit(0);
    }

    void carregarRecorde(){
        try{
            if(arquivoRecorde.exists()){
                BufferedReader br = new BufferedReader(new FileReader(arquivoRecorde));
                String linha = br.readLine();
                if(linha!=null) recorde = Integer.parseInt(linha);
                br.close();
            }
        }catch(Exception e){e.printStackTrace();}
    }

    void salvarRecorde(int score){
        recorde = score;
        try{
            BufferedWriter bw = new BufferedWriter(new FileWriter(arquivoRecorde));
            bw.write(""+score);
            bw.close();
        }catch(Exception e){e.printStackTrace();}
    }

    public void paintComponent(Graphics g){
        super.paintComponent(g);

        // Comida
        g.setColor(Color.RED);
        g.fillOval(food.x*tile, food.y*tile, tile, tile);

        // Power-up
        if(powerUpAtivo){
            g.setColor(Color.YELLOW);
            g.fillOval(powerUp.x*tile, powerUp.y*tile, tile, tile);
        }

        // Cobra com segmentos coloridos
        for(int i=0;i<snake.size();i++){
            Point p = snake.get(i);
            g.setColor(new Color(0, Math.min(255, 50+10*i),0));
            g.fillRect(p.x*tile, p.y*tile, tile, tile);
        }

        // Pontuação e recorde
        g.setColor(Color.WHITE);
        g.drawString("Score: "+score,10,20);
        g.drawString("Recorde: "+recorde,10,35);
    }

    public void keyPressed(KeyEvent e){
        int k = e.getKeyCode();
        if(k==KeyEvent.VK_UP && dy==0){ dx=0; dy=-1; }
        if(k==KeyEvent.VK_DOWN && dy==0){ dx=0; dy=1; }
        if(k==KeyEvent.VK_LEFT && dx==0){ dx=-1; dy=0; }
        if(k==KeyEvent.VK_RIGHT && dx==0){ dx=1; dy=0; }
    }

    public void keyReleased(KeyEvent e){}
    public void keyTyped(KeyEvent e){}

    public static void main(String[] args){
        JFrame janela = new JFrame("Snake Avançado");
        AdvancedSnakeGame jogo = new AdvancedSnakeGame();
        janela.add(jogo);
        janela.pack();
        janela.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        janela.setLocationRelativeTo(null);
        janela.setVisible(true);
    }
}
